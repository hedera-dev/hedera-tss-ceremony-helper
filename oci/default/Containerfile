FROM eclipse-temurin:25.0.2_10-jre-ubi10-minimal

# ── metadata ────────────────────────────────────────────────────────────────
LABEL org.opencontainers.image.title="hedera-tss-ceremony-helper" \
      org.opencontainers.image.description="Hedera TSS Ceremony Helper" \
      org.opencontainers.image.base.name="docker.io/library/eclipse-temurin:25.0.2_10-jre-ubi10-minimal"

# TARGETARCH is set automatically by Podman/BuildKit (e.g. amd64, arm64).
ARG TARGETARCH

# ── install curl (runtime download) and tini (PID 1 / signal forwarding) ─────
# tini is not in the UBI10 repos so we fetch it directly from GitHub releases.
RUN microdnf install -y curl \
 && microdnf clean all \
 && curl -fsSL "https://github.com/krallin/tini/releases/download/v0.19.0/tini-${TARGETARCH}" \
      -o /sbin/tini \
 && chmod +x /sbin/tini

# ── runtime user (non-root, UID 1000) ────────────────────────────────────────
RUN groupadd --gid 1000 appgroup \
 && useradd  --uid 1000 --gid appgroup --no-create-home appuser

WORKDIR /app

# ── entrypoint script ────────────────────────────────────────────────────────
COPY --chown=appuser:appgroup entrypoint.sh entrypoint.sh
RUN chmod +x entrypoint.sh

USER appuser

ENTRYPOINT ["/sbin/tini", "--", "/app/entrypoint.sh"]
